# =============================================================================
# RiskRadar — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The backend loads these via pydantic-settings (see backend/config/settings.py).
# The .env file should be in the project root (same level as backend/ folder).
# =============================================================================

# --- JWT Authentication (REQUIRED) -----------------------------------------
# Secret key for signing JWT tokens. Generate a random one:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE-ME-generate-a-random-secret

# Token lifetime in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=your-token-expiry-minutes-here

# --- Database ---------------------------------------------------------------
# For local development, SQLite is used automatically (no config needed).
# For production, set a MySQL/MariaDB connection string:
# e.g. DATABASE_URL=mysql+pymysql://user:pass@host:3306/riskradar
DATABASE_URL=your-database-url-here
DB_PATH=your-db-path-here

# --- LLM (optional for summaries/web scrapers; defaults are safe) -----------
# Canonical provider selector. Supported values:
#   openrouter (default), openai, deepseek, anthropic
LLM_PROVIDER=openrouter

# Preferred API key field. OPENROUTER_API_KEY is still accepted for compatibility.
LLM_API_KEY=
OPENROUTER_API_KEY=

# Model names used by the summarizer. These default to safe demo-friendly values.
LLM_MODEL=gpt-4o-mini
LLM_MODEL_GUEST=gpt-4o-mini
LLM_MODEL_PREMIUM=gpt-4o
LLM_MAX_TOKENS=4000

# --- Scraper API Keys -------------------------------------------------------
AIRNOW_API_KEY=your-airnow-key
OpenAQ_API_KEY=your-openaq-key-here
NASA_FIRMS_MAP_KEY=your-nasa-key-here
FIRECRAWL_API_KEY=your-firecrawl-key-here

# --- App Defaults -----------------------------------------------------------
DEFAULT_ZIP_CODE=your-default-zip-code-here
DEFAULT_LAT=your-default-latitude-here
DEFAULT_LON=your-default-longitude-here
SCRAPE_INTERVAL_MINUTES=your-scrape-interval-here
